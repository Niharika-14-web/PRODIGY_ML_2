    from sklearn.preprocessing import StandardScaler

# STEP 1: Feature Selection
# Drop CustomerID as it's an identifier and not useful for clustering
X = df[['Age', 'Annual Income (k$)', 'Spending Score (1-100)']]
print("Selected features (X.head()):")
print(X.head())

# STEP 2: Feature Scaling
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)

print("\nScaled features (first 5 rows of X_scaled):")
print(X_scaled[:5])
from sklearn.cluster import KMeans
import matplotlib.pyplot as plt

wcss = []

for k in range(1, 11):
    kmeans = KMeans(n_clusters=k, random_state=42, n_init=10)
    kmeans.fit(X_scaled)
    wcss.append(kmeans.inertia_)

plt.figure(figsize=(10, 6))
plt.plot(range(1, 11), wcss, marker='o', linestyle='--')
plt.xlabel('Number of Clusters (K)')
plt.ylabel('WCSS')
plt.title('Elbow Method for Optimal K')
plt.grid(True)
plt.show()

print("WCSS values calculated for K from 1 to 10.")
from sklearn.cluster import KMeans

# STEP 4: Apply K-Means
# Based on the Elbow Method plot, let's choose k=5 as the optimal number of clusters.
# There is a noticeable bend at k=3, k=4 and k=5, but k=5 seems to provide a good balance.
# For demonstration, I will use k=5.
k = 5  # Optimal number of clusters chosen from the elbow curve

kmeans = KMeans(n_clusters=k, random_state=42, n_init=10)

# Fit KMeans to the scaled data and predict clusters
df['Cluster'] = kmeans.fit_predict(X_scaled)

print(f"K-Means clustering applied with {k} clusters.")
print("First 5 rows of DataFrame with new 'Cluster' column:")
print(df.head())
import matplotlib.pyplot as plt
import seaborn as sns

# STEP 5: Cluster Analysis
print("Cluster characteristics (mean of features per cluster):")
print(df.groupby('Cluster')[['Age', 'Annual Income (k$)', 'Spending Score (1-100)']].mean().round(2))

# Visualize the clusters
plt.figure(figsize=(10, 8))
sns.scatterplot(
    x='Annual Income (k$)',
    y='Spending Score (1-100)',
    hue='Cluster',
    data=df,
    palette='viridis',
    s=100, # size of points
    alpha=0.8 # transparency
)
plt.title('Customer Segments by Annual Income and Spending Score')
plt.xlabel('Annual Income (k$)')
plt.ylabel('Spending Score (1-100)')
plt.legend(title='Cluster')
plt.grid(True, linestyle='--', alpha=0.6)
plt.show()